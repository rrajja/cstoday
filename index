<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>CSTODAY</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Nunito+Sans:wght@400;600&display=swap" rel="stylesheet">
<style>
/* ===== RESET & ROOT ===== */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --green:#00a884;--green-dark:#008069;--green-light:#d9fdd3;--green-glow:#00a88433;
  --bg:#111b21;--panel:#202c33;--panel2:#2a3942;--panel3:#374045;
  --border:#374045;--text:#e9edef;--text2:#aebac1;--text3:#8696a0;
  --out:#005c4b;--in:#202c33;--red:#f15c6d;--blue:#53bdeb;--amber:#ffb347;
  --radius:12px;--font:'Nunito',sans-serif;
}
html,body{height:100%;overflow:hidden;background:var(--bg);font-family:var(--font)}

/* ===== APP SHELL ===== */
#app{
  max-width:430px;width:100%;height:100vh;margin:0 auto;
  display:flex;flex-direction:column;overflow:hidden;position:relative;
  background:var(--bg);
}

/* ===== SPLASH ===== */
#splash{
  position:absolute;inset:0;background:var(--bg);z-index:200;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;
  transition:opacity .5s ease;
}
.splash-ring{
  width:100px;height:100px;border-radius:50%;
  border:3px solid var(--green);display:flex;align-items:center;justify-content:center;
  animation:spin-ring 2s linear infinite;
}
@keyframes spin-ring{to{transform:rotate(360deg)}}
.splash-inner{
  position:absolute;width:88px;height:88px;border-radius:50%;
  background:var(--green);display:flex;align-items:center;justify-content:center;
}
.splash-logo-wrap{position:relative;width:100px;height:100px;display:flex;align-items:center;justify-content:center}
.splash-name{font-size:28px;font-weight:800;letter-spacing:3px;color:var(--green)}
.splash-sub{font-size:12px;color:var(--text3);letter-spacing:1px}
.splash-progress{width:140px;height:2px;background:var(--border);border-radius:1px;overflow:hidden}
.splash-bar{height:100%;background:var(--green);animation:prog 2.5s ease-in-out forwards}
@keyframes prog{0%{width:0}60%{width:70%}100%{width:100%}}

/* ===== AUTH SCREEN ===== */
#authScreen{
  position:absolute;inset:0;background:var(--bg);z-index:150;
  display:none;flex-direction:column;align-items:center;justify-content:center;
  padding:32px 24px;gap:24px;
}
.auth-logo{width:80px;height:80px;background:var(--green);border-radius:24px;
  display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.auth-title{font-size:22px;font-weight:800;color:var(--text);text-align:center}
.auth-sub{font-size:14px;color:var(--text3);text-align:center;line-height:1.6;max-width:280px}
.auth-card{background:var(--panel);border-radius:16px;padding:20px;width:100%;max-width:340px}
.auth-card-title{font-size:13px;font-weight:700;color:var(--text2);margin-bottom:12px;letter-spacing:.5px;text-transform:uppercase}
.auth-input{
  width:100%;background:var(--panel2);border:1px solid var(--border);border-radius:10px;
  padding:12px 14px;color:var(--text);font-size:14px;font-family:var(--font);
  outline:none;transition:.2s;margin-bottom:10px;
}
.auth-input:focus{border-color:var(--green)}
.auth-input::placeholder{color:var(--text3)}
.btn-primary{
  width:100%;padding:14px;background:var(--green);border:none;border-radius:12px;
  color:#fff;font-size:15px;font-weight:700;font-family:var(--font);
  cursor:pointer;transition:.2s;letter-spacing:.5px;
}
.btn-primary:hover{background:var(--green-dark)}
.btn-primary:active{transform:scale(.98)}
.btn-google{
  width:100%;padding:13px;background:var(--panel2);border:1px solid var(--border);
  border-radius:12px;color:var(--text);font-size:14px;font-weight:600;
  font-family:var(--font);cursor:pointer;transition:.2s;display:flex;
  align-items:center;justify-content:center;gap:10px;
}
.btn-google:hover{background:var(--panel3)}
.divider{display:flex;align-items:center;gap:10px;color:var(--text3);font-size:12px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border)}
.setup-note{font-size:11px;color:var(--text3);text-align:center;line-height:1.5}
.setup-note a{color:var(--green);text-decoration:none}

/* ===== HEADER ===== */
.header{
  background:var(--panel);padding:12px 16px;
  display:flex;align-items:center;gap:12px;
  border-bottom:1px solid var(--border);flex-shrink:0;
}
.header-title{font-size:19px;font-weight:800;color:var(--green);flex:1;letter-spacing:1px}
.icon-btn{
  width:36px;height:36px;border-radius:50%;border:none;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;background:transparent;color:var(--text2);transition:.15s;
}
.icon-btn:hover{background:var(--panel2);color:var(--text)}

/* ===== TABS ===== */
.tabs{display:flex;background:var(--panel);border-bottom:2px solid var(--border);flex-shrink:0}
.tab{
  flex:1;padding:13px 4px;text-align:center;font-size:12px;font-weight:700;
  color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;
  transition:.2s;margin-bottom:-2px;letter-spacing:.3px;
}
.tab.active{color:var(--green);border-color:var(--green)}
.tab-badge{
  display:inline-flex;align-items:center;justify-content:center;
  background:var(--green);color:#fff;border-radius:10px;
  width:17px;height:17px;font-size:10px;font-weight:700;
  margin-left:4px;vertical-align:middle;
}

/* ===== DRIVE BAR ===== */
.drive-bar{
  background:var(--panel2);padding:6px 14px;font-size:11px;color:var(--text3);
  display:flex;align-items:center;gap:8px;flex-shrink:0;
  border-bottom:1px solid var(--border);
}
.drive-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.drive-dot.connected{background:var(--green)}
.drive-dot.disconnected{background:var(--red)}
.drive-dot.syncing{background:var(--amber);animation:blink .8s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* ===== SCREENS ===== */
.screen{display:none;flex-direction:column;flex:1;overflow:hidden}
.screen.active{display:flex}

/* ===== CHAT LIST ===== */
.search-bar{
  padding:8px 12px;background:var(--panel);border-bottom:1px solid var(--border);flex-shrink:0;
}
.search-input{
  width:100%;background:var(--panel2);border:none;border-radius:24px;
  padding:9px 16px 9px 36px;color:var(--text);font-size:14px;font-family:var(--font);
  outline:none;background-image:url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%238696a0' stroke-width='2' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='11' cy='11' r='8'/%3E%3Cpath d='m21 21-4.35-4.35'/%3E%3C/svg%3E");
  background-repeat:no-repeat;background-position:12px center;
}
.search-input::placeholder{color:var(--text3)}

.chat-list{flex:1;overflow-y:auto}
.chat-list::-webkit-scrollbar{width:3px}
.chat-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

.chat-row{
  display:flex;align-items:center;gap:12px;padding:12px 16px;
  cursor:pointer;border-bottom:1px solid var(--border);transition:.12s;
}
.chat-row:hover{background:var(--panel2)}
.chat-row:active{background:var(--panel3)}
.avatar{
  width:48px;height:48px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;
}
.chat-info{flex:1;min-width:0}
.chat-name{font-size:15px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:6px}
.group-icon{opacity:.6}
.chat-preview{font-size:13px;color:var(--text3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;display:flex;align-items:center;gap:4px}
.chat-meta{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0}
.chat-time{font-size:11px;color:var(--text3)}
.chat-time.unread{color:var(--green)}
.unread-badge{
  background:var(--green);color:#fff;border-radius:10px;
  min-width:20px;height:20px;padding:0 5px;
  display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;
}
.muted-badge{
  background:var(--panel3);color:var(--text3);border-radius:10px;
  width:20px;height:20px;display:flex;align-items:center;justify-content:center;
}

/* ===== CHAT VIEW ===== */
#chatView{
  position:absolute;inset:0;z-index:30;background:var(--bg);
  display:none;flex-direction:column;
}
.chat-view-header{
  background:var(--panel);padding:10px 12px;
  display:flex;align-items:center;gap:10px;
  border-bottom:1px solid var(--border);flex-shrink:0;
}
.cv-info{flex:1;min-width:0}
.cv-name{font-size:15px;font-weight:700;color:var(--text)}
.cv-status{font-size:12px;color:var(--green);margin-top:1px}
.cv-status.away{color:var(--text3)}

.messages{flex:1;overflow-y:auto;padding:10px 10px 8px;display:flex;flex-direction:column;gap:3px;background:var(--bg)}
.messages::-webkit-scrollbar{width:3px}
.messages::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

.date-sep{
  align-self:center;background:var(--panel2);color:var(--text3);
  font-size:11px;border-radius:8px;padding:4px 12px;margin:8px 0;flex-shrink:0;
}
.msg-wrap{display:flex;flex-direction:column;max-width:78%}
.msg-wrap.out{align-self:flex-end;align-items:flex-end}
.msg-wrap.in{align-self:flex-start;align-items:flex-start}
.msg-sender-name{font-size:11px;color:var(--green);font-weight:700;margin-bottom:2px;padding-left:4px}
.bubble{
  border-radius:12px;padding:8px 12px;font-size:14px;line-height:1.5;
  word-break:break-word;animation:msgPop .18s ease;position:relative;
}
@keyframes msgPop{from{opacity:0;transform:scale(.94) translateY(4px)}to{opacity:1;transform:scale(1) translateY(0)}}
.bubble.out{background:var(--out);border-bottom-right-radius:3px}
.bubble.in{background:var(--in);border-bottom-left-radius:3px}
.msg-footer{
  display:flex;align-items:center;justify-content:flex-end;gap:4px;
  margin-top:3px;padding:0 2px;
}
.msg-time-txt{font-size:10px;color:var(--text3)}
.tick{font-size:12px;color:var(--text3)}
.tick.read{color:var(--blue)}

/* FILE BUBBLES */
.file-bubble{display:flex;align-items:center;gap:10px;min-width:190px;max-width:240px}
.file-thumb{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.file-details{flex:1;min-width:0}
.file-fname{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.file-fmeta{font-size:11px;color:var(--text3);margin-top:2px}
.file-flink{color:var(--green);font-size:11px}
.img-bubble{max-width:220px;width:100%;border-radius:10px;cursor:zoom-in;display:block}

/* ===== INPUT BAR ===== */
.input-area{
  background:var(--panel);padding:8px 10px;
  display:flex;align-items:flex-end;gap:8px;
  border-top:1px solid var(--border);flex-shrink:0;position:relative;
}
.attach-btn,.emoji-btn,.send-btn,.mic-btn{
  width:40px;height:40px;border-radius:50%;border:none;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.15s;
}
.attach-btn,.emoji-btn,.mic-btn{background:transparent;color:var(--text3)}
.attach-btn:hover,.emoji-btn:hover,.mic-btn:hover{background:var(--panel2);color:var(--text2)}
.send-btn{background:var(--green);color:#fff}
.send-btn:hover{background:var(--green-dark)}
.send-btn:active{transform:scale(.95)}
.msg-textarea{
  flex:1;background:var(--panel2);border:none;border-radius:22px;
  padding:10px 14px;color:var(--text);font-size:14px;font-family:var(--font);
  resize:none;outline:none;max-height:110px;line-height:1.45;
}
.msg-textarea::placeholder{color:var(--text3)}

/* ===== ATTACH POPUP ===== */
.attach-popup{
  position:absolute;bottom:62px;left:8px;
  background:var(--panel);border-radius:18px;padding:16px 12px;
  display:none;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:10;
  animation:popUp .2s ease;
}
.attach-popup.open{display:block}
@keyframes popUp{from{opacity:0;transform:scale(.9) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
.attach-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.attach-item{
  display:flex;flex-direction:column;align-items:center;gap:6px;
  padding:10px 8px;border-radius:12px;cursor:pointer;transition:.15s;
}
.attach-item:hover{background:var(--panel2)}
.attach-circle{
  width:48px;height:48px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
}
.attach-label{font-size:11px;color:var(--text3);text-align:center}

/* ===== FILES SCREEN ===== */
.files-toolbar{
  padding:10px 14px;display:flex;align-items:center;gap:8px;
  background:var(--panel);border-bottom:1px solid var(--border);flex-shrink:0;
}
.filter-btn{
  padding:6px 14px;border-radius:20px;border:1px solid var(--border);
  background:transparent;color:var(--text3);font-size:12px;font-weight:600;
  font-family:var(--font);cursor:pointer;transition:.2s;
}
.filter-btn.active{background:var(--green);color:#fff;border-color:var(--green)}
.files-scroll{flex:1;overflow-y:auto;padding:10px}
.files-scroll::-webkit-scrollbar{width:3px}
.section-label{font-size:11px;font-weight:700;color:var(--text3);padding:6px 4px 8px;letter-spacing:.8px;text-transform:uppercase}
.file-card{
  display:flex;align-items:center;gap:12px;padding:12px;
  background:var(--panel);border-radius:14px;margin-bottom:8px;
  cursor:pointer;transition:.15s;border:1px solid transparent;
}
.file-card:hover{background:var(--panel2);border-color:var(--border)}
.file-card-icon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.file-card-info{flex:1;min-width:0}
.file-card-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.file-card-meta{font-size:11px;color:var(--text3);margin-top:3px}
.drive-chip{
  background:var(--green);color:#fff;font-size:9px;font-weight:800;
  padding:2px 7px;border-radius:8px;letter-spacing:.5px;
}
.empty-state{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:60px 24px;gap:12px;
}
.empty-icon{opacity:.25}
.empty-text{font-size:14px;color:var(--text3);text-align:center}
.empty-sub{font-size:12px;color:var(--text3);opacity:.6;text-align:center}

/* ===== CALLS SCREEN ===== */
.call-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:32px}

/* ===== STATUS SCREEN ===== */
.my-status-card{
  margin:12px;background:var(--panel);border-radius:16px;
  padding:16px;display:flex;align-items:center;gap:14px;cursor:pointer;
  border:1px solid var(--border);
}
.status-add-ring{
  width:54px;height:54px;border-radius:50%;border:2px dashed var(--border);
  display:flex;align-items:center;justify-content:center;position:relative;
}
.status-ring{
  width:54px;height:54px;border-radius:50%;
  border:2px solid var(--green);padding:2px;flex-shrink:0;
}
.status-av{width:100%;height:100%;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px}
.status-info .title{font-size:14px;font-weight:600;color:var(--text)}
.status-info .sub{font-size:12px;color:var(--text3);margin-top:2px}
.status-list{overflow-y:auto;flex:1}
.status-row{display:flex;align-items:center;gap:12px;padding:12px 16px;cursor:pointer;border-bottom:1px solid var(--border)}

/* ===== FAB ===== */
.fab{
  position:absolute;bottom:20px;right:16px;width:54px;height:54px;
  background:var(--green);border-radius:50%;border:none;
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  box-shadow:0 4px 18px var(--green-glow);transition:.2s;color:#fff;
}
.fab:hover{background:var(--green-dark);transform:scale(1.05)}
.fab:active{transform:scale(.97)}

/* ===== MODAL ===== */
.modal-bg{
  position:absolute;inset:0;background:rgba(0,0,0,.7);z-index:50;
  display:none;align-items:flex-end;
}
.modal-bg.open{display:flex;animation:fadeIn .2s}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal-sheet{
  background:var(--panel);width:100%;border-radius:24px 24px 0 0;
  padding:20px 16px 28px;animation:slideUp .25s ease;
}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
.modal-close{cursor:pointer;color:var(--text3);font-size:22px;line-height:1;background:none;border:none;color:var(--text3)}
.contact-item{display:flex;align-items:center;gap:12px;padding:11px 4px;cursor:pointer;border-radius:12px;transition:.15s}
.contact-item:hover{background:var(--panel2)}

/* ===== TOAST ===== */
.toast{
  position:absolute;bottom:76px;left:50%;transform:translateX(-50%);
  background:var(--panel2);border-radius:24px;padding:10px 20px;
  font-size:12px;color:var(--text);white-space:nowrap;z-index:100;
  display:none;box-shadow:0 4px 20px rgba(0,0,0,.4);border:1px solid var(--border);
  align-items:center;gap:8px;
}
.toast.show{display:flex;animation:msgPop .25s ease}

/* ===== IMAGE VIEWER ===== */
#imgViewer{
  position:absolute;inset:0;background:rgba(0,0,0,.93);z-index:200;
  display:none;align-items:center;justify-content:center;
}
#imgViewer.open{display:flex}
#imgViewer img{max-width:95%;max-height:90vh;border-radius:8px}
#imgViewer .close-viewer{
  position:absolute;top:16px;right:16px;background:rgba(255,255,255,.15);
  border:none;color:#fff;width:38px;height:38px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
</style>
</head>
<body>
<div id="app">

<!-- SPLASH -->
<div id="splash">
  <div class="splash-logo-wrap">
    <div class="splash-ring"></div>
    <div class="splash-inner">
      <svg width="46" height="46" viewBox="0 0 52 52" fill="none">
        <path d="M10 26C10 16 16 10 26 10C36 10 42 16 42 26C42 34 37 40 30 42L26 46L22 42C15 40 10 34 10 26Z" fill="white"/>
        <circle cx="19" cy="26" r="2.5" fill="#00a884"/>
        <circle cx="26" cy="26" r="2.5" fill="#00a884"/>
        <circle cx="33" cy="26" r="2.5" fill="#00a884"/>
      </svg>
    </div>
  </div>
  <div class="splash-name">CSTODAY</div>
  <div class="splash-sub">CONNECT · SHARE · TODAY</div>
  <div class="splash-progress"><div class="splash-bar"></div></div>
</div>

<!-- AUTH SCREEN -->
<div id="authScreen">
  <div class="auth-logo">
    <svg width="44" height="44" viewBox="0 0 52 52" fill="none">
      <path d="M10 26C10 16 16 10 26 10C36 10 42 16 42 26C42 34 37 40 30 42L26 46L22 42C15 40 10 34 10 26Z" fill="white"/>
      <circle cx="19" cy="26" r="2.5" fill="#00a884"/>
      <circle cx="26" cy="26" r="2.5" fill="#00a884"/>
      <circle cx="33" cy="26" r="2.5" fill="#00a884"/>
    </svg>
  </div>
  <div class="auth-title">Welcome to CSTODAY</div>
  <div class="auth-sub">Connect, chat and share files instantly. Sign in to sync everything with your Google Drive.</div>

  <div class="auth-card">
    <div class="auth-card-title">Your Display Name</div>
    <input class="auth-input" type="text" id="displayName" placeholder="Enter your name" maxlength="30">
    <div class="auth-card-title" style="margin-top:4px">Phone / Username</div>
    <input class="auth-input" type="text" id="userHandle" placeholder="+91 98765 43210 or @username" maxlength="30">
    <button class="btn-primary" onclick="signInLocal()" style="margin-top:4px">Continue</button>
  </div>

