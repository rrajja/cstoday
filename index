  state.contacts.forEach(c=>{c.unread=Math.floor(Math.random()*3);c.lastMsg=state.chats[c.id]?.slice(-1)[0]||null;});
}

// ---- HELPERS ----
function getTime(){const d=new Date();return String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0');}
function formatBytes(b){if(b>1048576)return(b/1048576).toFixed(1)+' MB';return(b/1024).toFixed(0)+' KB';}
function getFileType(name,mime){
  if(mime&&mime.startsWith('image/'))return'image';
  if(mime==='application/pdf'||name.endsWith('.pdf'))return'pdf';
  return'file';
}
function getFileColor(type){return type==='pdf'?'#e53935':type==='image'?'#1976d2':'#c8934a';}
function getFileIcon(type){
  if(type==='pdf')return`<svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="1.5"/><line x1="8" y1="13" x2="16" y2="13" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/><line x1="8" y1="17" x2="13" y2="17" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/></svg>`;
  if(type==='image')return`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5" fill="white"/><polyline points="21,15 16,10 5,21"/></svg>`;
  return`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13,2 13,9 20,9"/></svg>`;
}

// ---- TOAST ----
let toastTimer;
function showToast(msg,dur=2500){
  clearTimeout(toastTimer);
  document.getElementById('toastText').textContent=msg;
  document.getElementById('toast').classList.add('show');
  toastTimer=setTimeout(()=>document.getElementById('toast').classList.remove('show'),dur);
}

// ---- SPLASH & INIT ----
window.onload=()=>{
  initDemoChats();
  setTimeout(()=>{
    const sp=document.getElementById('splash');
    sp.style.opacity='0';
    setTimeout(()=>{
      sp.style.display='none';
      const saved=localStorage.getItem('cstoday_user');
      if(saved){
        state.user=JSON.parse(saved);
        bootApp();
      } else {
        document.getElementById('authScreen').style.display='flex';
      }
    },500);
  },2600);
};

// ---- AUTH ----
function signInLocal(){
  const name=document.getElementById('displayName').value.trim();
  const handle=document.getElementById('userHandle').value.trim();
  if(!name){showToast('Please enter your name');return;}
  state.user={name,handle:handle||'@'+name.toLowerCase().replace(/\s+/g,''),type:'local'};
  localStorage.setItem('cstoday_user',JSON.stringify(state.user));
  bootApp();
}

function signInWithGoogle(){
  // Google OAuth2 — requires client_id to be configured
  const CLIENT_ID='YOUR_GOOGLE_CLIENT_ID'; // Replace with actual client ID
  if(CLIENT_ID==='YOUR_GOOGLE_CLIENT_ID'){
    showToast('Configure Google Client ID to enable OAuth');
    // Simulate for demo
    state.user={name:'CS User',handle:'@csuser',type:'google',email:'user@gmail.com'};
    localStorage.setItem('cstoday_user',JSON.stringify(state.user));
    bootApp();
    return;
  }
  const scope='https://www.googleapis.com/auth/drive.file https://www.googleapis.com/auth/userinfo.profile';
  const redirect=encodeURIComponent(window.location.href.split('?')[0]);
  const url=`https://accounts.google.com/o/oauth2/v2/auth?client_id=${CLIENT_ID}&redirect_uri=${redirect}&response_type=token&scope=${encodeURIComponent(scope)}`;
  window.location.href=url;
}

// Handle OAuth callback
(function handleOAuthCallback(){
  if(location.hash.includes('access_token=')){
    const params=new URLSearchParams(location.hash.slice(1));
    state.accessToken=params.get('access_token');
    if(state.accessToken){
      fetchGoogleProfile(state.accessToken);
      history.replaceState(null,'',location.pathname);
    }
  }
})();

function fetchGoogleProfile(token){
  fetch('https://www.googleapis.com/oauth2/v2/userinfo',{headers:{Authorization:'Bearer '+token}})
  .then(r=>r.json()).then(profile=>{
    state.user={name:profile.name,email:profile.email,picture:profile.picture,type:'google'};
    localStorage.setItem('cstoday_user',JSON.stringify(state.user));
    state.driveConnected=true;
    bootApp();
  }).catch(()=>{
    state.user={name:'Google User',type:'google'};
    bootApp();
  });
}

function bootApp(){
  document.getElementById('authScreen').style.display='none';
  document.getElementById('mainApp').style.display='flex';
  document.getElementById('mainApp').style.flexDirection='column';
  document.getElementById('mainApp').style.height='100%';
  document.getElementById('mainApp').style.overflow='hidden';
  updateDriveBar();
  renderChatList();
  renderStatusScreen();
  renderFilesList('all');
}

// ---- DRIVE BAR ----
function updateDriveBar(){
  const dot=document.getElementById('driveDot');
  const txt=document.getElementById('driveBarText');
  if(state.accessToken||state.driveConnected){
    dot.className='drive-dot connected';
    txt.textContent='Google Drive connected · Syncing CSTODAY folder';
    state.driveConnected=true;
  } else {
    dot.className='drive-dot disconnected';
    txt.textContent='Google Drive — tap SYNC to connect';
  }
}

function syncDrive(){
  const dot=document.getElementById('driveDot');
  dot.className='drive-dot syncing';
  document.getElementById('driveBarText').textContent='Syncing with Google Drive...';
  setTimeout(()=>{
    dot.className='drive-dot connected';
    document.getElementById('driveBarText').textContent='Synced · Google Drive connected';
    showToast('Drive synced ✓');
    if(state.accessToken) loadDriveFiles();
  },1800);
}

// ---- DRIVE API ----
async function uploadToDrive(file, onProgress){
  if(!state.accessToken){
    showToast('Sign in with Google to sync files to Drive');
    return simulateDriveUpload(file);
  }
  const metadata={name:file.name,parents:[DRIVE_FOLDER_ID]};
  const form=new FormData();
  form.append('metadata',new Blob([JSON.stringify(metadata)],{type:'application/json'}));
  form.append('file',file);
  try{
    const res=await fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart&fields=id,name,webViewLink',{
      method:'POST',
      headers:{Authorization:'Bearer '+state.accessToken},
      body:form,
    });
    const data=await res.json();
    return {id:data.id,name:data.name,webViewLink:data.webViewLink,driveSync:true};
  }catch(e){
    return simulateDriveUpload(file);
  }
}

function simulateDriveUpload(file){
  return new Promise(resolve=>{
    setTimeout(()=>{
      resolve({id:'local_'+Date.now(),name:file.name,webViewLink:DRIVE_FOLDER_URL,driveSync:false});
    },1200);
  });
}

async function loadDriveFiles(){
  if(!state.accessToken)return;
  try{
    const res=await fetch(`https://www.googleapis.com/drive/v3/files?q='${DRIVE_FOLDER_ID}'+in+parents+and+trashed=false&fields=files(id,name,mimeType,size,webViewLink,createdTime)&orderBy=createdTime+desc`,{
      headers:{Authorization:'Bearer '+state.accessToken}
    });
    const data=await res.json();
    if(data.files){
      data.files.forEach(f=>{
        if(!state.files.find(x=>x.driveId===f.id)){
          state.files.push({
            driveId:f.id,name:f.name,
            type:getFileType(f.name,f.mimeType),
            size:formatBytes(parseInt(f.size)||0),
            date:new Date(f.createdTime).toLocaleDateString(),
            link:f.webViewLink,driveSync:true,
          });
        }
      });
      renderFilesList(state.currentFilter||'all');
    }
  }catch(e){console.warn('Drive API error',e);}
}

// ---- TABS ----
function switchTab(tab){
  ['chats','status','files','calls'].forEach(t=>{
    document.getElementById('tab-'+t).classList.toggle('active',t===tab);
    document.getElementById('screen-'+t).classList.toggle('active',t===tab);
  });
}

// ---- CHAT LIST ----
function renderChatList(filter=''){
  const el=document.getElementById('chatList');
  const filtered=state.contacts.filter(c=>!filter||c.name.toLowerCase().includes(filter.toLowerCase()));
  if(filtered.length===0){el.innerHTML=`<div style="text-align:center;padding:40px;color:var(--text3);font-size:14px">No chats found</div>`;return;}
  el.innerHTML=filtered.map(c=>{
    const msgs=state.chats[c.id]||[];
    const last=msgs[msgs.length-1];
    const preview=last?(last.file?`📎 ${last.file.name}`:(last.out?'You: ':'')+last.text):'';
    const lastTime=last?last.time:'';
    return`<div class="chat-row" onclick="openChat('${c.id}')">
      <div class="avatar" style="background:${c.color}22;color:${c.color}">${c.initials}</div>
      <div class="chat-info">
        <div class="chat-name">
          ${c.name}
          ${c.group?`<svg class="group-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`:''}
        </div>
        <div class="chat-preview">${preview||'Tap to chat'}</div>
      </div>
      <div class="chat-meta">
        <div class="chat-time ${c.unread?'unread':''}">${lastTime}</div>
        ${c.unread?`<div class="unread-badge">${c.unread}</div>`:''}
      </div>
    </div>`;
  }).join('');
}

let searchVisible=false;
function toggleSearch(){
  searchVisible=!searchVisible;
  document.getElementById('searchBar').style.display=searchVisible?'block':'none';
  if(searchVisible)document.getElementById('searchInput').focus();
}
function filterChats(v){renderChatList(v);}

// ---- OPEN CHAT ----
function openChat(id){
  state.currentChatId=id;
  const c=state.contacts.find(x=>x.id===id);
  document.getElementById('cvName').textContent=c.name;
  document.getElementById('cvStatus').textContent=c.status;
  document.getElementById('cvStatus').className='cv-status'+(c.status.includes('last')||c.status.includes('member')?' away':'');
  const av=document.getElementById('cvAvatar');
  av.textContent=c.initials;av.style.background=c.color+'22';av.style.color=c.color;
  c.unread=0;
  renderMessages();
  document.getElementById('chatView').style.display='flex';
  document.getElementById('msgInput').focus();
  renderChatList();
}

function closeChatView(){
  document.getElementById('chatView').style.display='none';
  state.currentChatId=null;
  renderChatList();
}

// ---- MESSAGES ----
function renderMessages(){
  const msgs=state.chats[state.currentChatId]||[];
  const el=document.getElementById('messages');
  const c=state.contacts.find(x=>x.id===state.currentChatId);
  el.innerHTML=`<div class="date-sep">Today</div>`+msgs.map(m=>{
    const isOut=m.out;
    if(m.file)return renderFileBubble(m,c);
    return`<div class="msg-wrap ${isOut?'out':'in'}">
      ${c.group&&!isOut?`<div class="msg-sender-name">${m.sender||'Member'}</div>`:''}
      <div class="bubble ${isOut?'out':'in'}">${escHtml(m.text)}</div>
      <div class="msg-footer">
        <span class="msg-time-txt">${m.time}</span>
        ${isOut?`<span class="tick ${m.read?'read':''}">✓✓</span>`:''}
      </div>
    </div>`;
  }).join('');
  el.scrollTop=el.scrollHeight;
}

function renderFileBubble(m,c){
  const f=m.file;const isOut=m.out;
  if(f.type==='image'&&f.dataUrl){
    return`<div class="msg-wrap ${isOut?'out':'in'}">
      ${c.group&&!isOut?`<div class="msg-sender-name">${m.sender||'Member'}</div>`:''}
      <div class="bubble ${isOut?'out':'in'}" style="padding:5px">
        <img src="${f.dataUrl}" class="img-bubble" onclick="openImgViewer('${f.dataUrl}')">
        <div class="msg-footer" style="padding:4px 4px 0">
          <span class="msg-time-txt">${m.time}</span>
          ${isOut?`<span class="tick">✓✓</span>`:''}
        </div>
      </div>
    </div>`;
  }
  const color=getFileColor(f.type);
  const icon=getFileIcon(f.type);
  return`<div class="msg-wrap ${isOut?'out':'in'}">
    ${c.group&&!isOut?`<div class="msg-sender-name">${m.sender||'Member'}</div>`:''}
    <div class="bubble ${isOut?'out':'in'}">
      <div class="file-bubble">
        <div class="file-thumb" style="background:${color}">${icon}</div>
        <div class="file-details">
          <div class="file-fname">${escHtml(f.name)}</div>
          <div class="file-fmeta">${f.size} · <a class="file-flink" href="${f.link||DRIVE_FOLDER_URL}" target="_blank">${f.driveSync?'Drive ↗':'Saved locally'}</a></div>
        </div>
      </div>
      <div class="msg-footer">
        <span class="msg-time-txt">${m.time}</span>
        ${isOut?`<span class="tick">✓✓</span>`:''}
      </div>
    </div>
  </div>`;
}

function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

// ---- SEND MESSAGE ----
function sendMsg(){
  const inp=document.getElementById('msgInput');
  const text=inp.value.trim();
  if(!text||!state.currentChatId)return;
  const msg={id:Date.now(),text,time:getTime(),out:true,read:false};
  (state.chats[state.currentChatId]=state.chats[state.currentChatId]||[]).push(msg);
  inp.value='';inp.style.height='auto';
  renderMessages();
  scheduleReply();
}

function handleMsgKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,110)+'px';}

const REPLIES=['Got it! 👍','Thanks for sharing!','Can you also send the PDF version?','Looks great!','On it! Will check now.','Perfect, received ✓','Will get back to you','Sure thing! 🙌','Awesome, thanks!','Noted 👍'];
function scheduleReply(){
  setTimeout(()=>{
    const c=state.contacts.find(x=>x.id===state.currentChatId);
    if(!c)return;
    const r={id:Date.now(),text:REPLIES[Math.floor(Math.random()*REPLIES.length)],time:getTime(),out:false,sender:c.name.split(' ')[0]};
    state.chats[state.currentChatId].push(r);
    renderMessages();
  },1000+Math.random()*1500);
}

// ---- ATTACH ----
let attachOpen=false;
function toggleAttachPopup(){attachOpen=!attachOpen;document.getElementById('attachPopup').classList.toggle('open',attachOpen);}
function closeAttachPopup(){attachOpen=false;document.getElementById('attachPopup').classList.remove('open');}
function triggerFilePick(type){
  closeAttachPopup();
  if(type==='pdf')document.getElementById('pdfPicker').click();
  else if(type==='image')document.getElementById('imagePicker').click();
  else document.getElementById('anyPicker').click();
}

async function handleAttach(input,type){
  if(!input.files||!input.files[0])return;
  const file=input.files[0];
  const ftype=getFileType(file.name,file.type);
  const sizeStr=formatBytes(file.size);
  showToast('Uploading to Google Drive...',3000);
  const driveResult=await uploadToDrive(file);
  const fileObj={name:file.name,type:ftype,size:sizeStr,link:driveResult.webViewLink||DRIVE_FOLDER_URL,driveSync:driveResult.driveSync};
  
  if(ftype==='image'){
    const reader=new FileReader();
    reader.onload=e=>{
      fileObj.dataUrl=e.target.result;
      pushFileMsg(fileObj);
      addToFilesList(fileObj);
    };
    reader.readAsDataURL(file);
  } else {
    pushFileMsg(fileObj);
    addToFilesList(fileObj);
  }
  input.value='';
  showToast(driveResult.driveSync?'Uploaded to Google Drive ✓':'Saved locally ✓');
}

function pushFileMsg(fileObj){
  if(!state.currentChatId)return;
  const msg={id:Date.now(),file:fileObj,time:getTime(),out:true};
  (state.chats[state.currentChatId]=state.chats[state.currentChatId]||[]).push(msg);
  renderMessages();
  setTimeout(scheduleReply,800);
}

function addToFilesList(f){
  state.files.unshift({...f,date:new Date().toLocaleDateString()});
  renderFilesList(state.currentFilter||'all');
}

async function handleGlobalUpload(input){
  if(!input.files||!input.files[0])return;
  const file=input.files[0];
  const ftype=getFileType(file.name,file.type);
  showToast('Uploading to Google Drive...',3000);
  const dr=await uploadToDrive(file);
  const fo={name:file.name,type:ftype,size:formatBytes(file.size),date:new Date().toLocaleDateString(),link:dr.webViewLink||DRIVE_FOLDER_URL,driveSync:dr.driveSync};
  if(ftype==='image'){
    const reader=new FileReader();
    reader.onload=e=>{fo.dataUrl=e.target.result;state.files.unshift(fo);renderFilesList(state.currentFilter||'all');};
    reader.readAsDataURL(file);
  } else {
    state.files.unshift(fo);renderFilesList(state.currentFilter||'all');
  }
  input.value='';
  showToast(dr.driveSync?'Uploaded to Drive ✓':'Saved locally ✓');
}

// ---- FILES SCREEN ----
state.currentFilter='all';
function filterFiles(type,btn){
  state.currentFilter=type;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderFilesList(type);
}

function renderFilesList(filter){
  const el=document.getElementById('filesList');
  const list=filter==='all'?state.files:state.files.filter(f=>f.type===filter);
  if(list.length===0){
    el.innerHTML=`<div class="empty-state">
      <svg class="empty-icon" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--text2)" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,9 20,9"/></svg>
      <div class="empty-text">No files yet</div>
      <div class="empty-sub">Files you send or upload will appear here and sync to your Google Drive folder.</div>
    </div>`;
    return;
  }
  el.innerHTML=`<div class="section-label" style="display:flex;align-items:center;gap:8px">All Files <span class="drive-chip">GOOGLE DRIVE</span></div>`+list.map((f,i)=>{
    const color=getFileColor(f.type);const icon=getFileIcon(f.type);
    return`<div class="file-card" onclick="openFile('${i}')">
      <div class="file-card-icon" style="background:${color}">${icon}</div>
      <div class="file-card-info">
        <div class="file-card-name">${escHtml(f.name)}</div>
        <div class="file-card-meta">${f.size} · ${f.date}${f.driveSync?' · <span style="color:var(--green)">Drive ↗</span>':''}</div>
      </div>
      ${f.dataUrl&&f.type==='image'?`<img src="${f.dataUrl}" style="width:40px;height:40px;border-radius:8px;object-fit:cover;flex-shrink:0">`: ''}
    </div>`;
  }).join('');
}

function openFile(idx){
  const f=state.files[idx];
  if(f&&f.link)window.open(f.link,'_blank');
  else if(f&&f.dataUrl)openImgViewer(f.dataUrl);
}

